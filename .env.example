# VERA — example environment file. Copy to `.env` (gitignored) and fill in.
# Most values have safe defaults; this file mostly documents the optional knobs.

# --- API server -------------------------------------------------------------

# Override the trained-model directory. Default search order is:
#   1. $VERA_MODEL_DIR
#   2. runs/cnn_v2
#   3. runs/cnn_run
# A warning is printed (not raised) at API import time if none of the above
# contains a `model.onnx`, so the server can still boot for /healthz + docs.
VERA_MODEL_DIR=runs/cnn_v2

# --- Web (Next.js) ----------------------------------------------------------

# Where the API runs in dev. The console reads this at build time.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# --- Bridge (mock_esp32 → bridge.py) ---------------------------------------

# Optional: override the serial port to read from instead of stdin.
# When unset, bridge.py reads JSON-Lines from stdin.
# VERA_BRIDGE_SERIAL=/dev/ttyUSB0
